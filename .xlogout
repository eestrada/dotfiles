#!/bin/sh

# run anything we want to run right before an X11 session ends.

# Based on: https://www.reddit.com/r/voidlinux/comments/lkjs6z/comment/go0hnxg/
# Browser name 'chrome' works for both chrome and chromium
# TODO: find a place in openrc/init to do this same thing so that a script isn't needed.

BROWSERS=chromium chromium-browser chrome brave

# First send the signal to kill any and all chromium derived browsers...
for browser in ${BROWSERS}; do
  printf 'Attempting to gracefully kill %s...\n' "$browser" 1>&2
  pkill --oldest -x "$browser"
done

# Then wait for them all to die.
for browser in ${BROWSERS}; do
  pid=$(pgrep --oldest -x "$browser")
  while kill -0 "${pid}"; do sleep 1; done
  printf '%s killed!\n' "$browser" 1>&2
done

# Kill the debus session started in .xinitrc
if [ -n "$DBUS_SESSION_BUS_PID" ]; then
  kill "$DBUS_SESSION_BUS_PID"
  while kill -0 "$DBUS_SESSION_BUS_PID"; do sleep 1; done
fi
